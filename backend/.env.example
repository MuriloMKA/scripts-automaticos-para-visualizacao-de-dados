# Copie este arquivo para .env e ajuste quando for integrar IA
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
OPENAI_BASE_URL=https://api.openai.com
REQUEST_TIMEOUT_SECONDS=60

# Auth JWT
JWT_SECRET_KEY=troque-esta-chave-em-producao
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# SAP OData (integracao real de leitura)
SAP_CONNECTOR_TYPE=odata
SAP_ODATA_BASE_URL=
SAP_ODATA_USERNAME=
SAP_ODATA_PASSWORD=

# CORS extra (se precisar): http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=
